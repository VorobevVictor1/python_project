# === Database ===
DATABASE_URL=sqlite:///./catalog.db

# === Queue ===
# Для локальной разработки: false (используется InMemoryQueue)
# Для продакшена: true (используется Redis)
USE_IN_MEMORY_QUEUE=true
REDIS_URL=redis://localhost:6379/0

# === Recommendations ===
RECOMMENDATION_TOP_N=10
RECOMMENDATION_MIN_RATINGS=3
RECOMMENDATION_MIN_SIMILARITY=0.1

# === App ===
ENVIRONMENT=development
LOG_LEVEL=INFO